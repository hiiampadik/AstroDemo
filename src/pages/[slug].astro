---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const subpages = await getCollection('subpages');
  return subpages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

interface Props {
  page: CollectionEntry<'subpages'>;
}

const { page } = Astro.props;
const { title, subtitle, graphic } = page.data;
const { Content } = await page.render();

const base = import.meta.env.BASE_URL;
// Frontmatter stores root-absolute paths (e.g. /images/foo.svg); prefix the
// deploy base so they resolve under the GitHub Pages subpath.
const graphicSrc = `${base}${graphic}`;
---

<Layout title={title}>
  <main>
    <article>
      <header>
        <h1>{title}</h1>
        <h2>{subtitle}</h2>
      </header>

      <img src={graphicSrc} alt={title} />

      <Content />
    </article>

    <p><a href={base}>&larr; Back to all subpages</a></p>
  </main>
</Layout>
