---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const subpages = await getCollection('subpages');
  return subpages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

interface Props {
  page: CollectionEntry<'subpages'>;
}

const { page } = Astro.props;
const { title, subtitle, graphic } = page.data;
const { Content } = await page.render();
---

<Layout title={title}>
  <main>
    <article>
      <header>
        <h1>{title}</h1>
        <h2>{subtitle}</h2>
      </header>

      <img src={graphic} alt={title} />

      <Content />
    </article>

    <p><a href="/">&larr; Back to all subpages</a></p>
  </main>
</Layout>
